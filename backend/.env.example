# ─────────────────────────────────────────────────────────────────────────────
# RAG Pipeline — Environment Variables Template
# Copy this file to .env and fill in your values.
# .env is GITIGNORED — never push it.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME="RAG Pipeline"
DEBUG=true

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/rag_db

# ── Elasticsearch ─────────────────────────────────────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200
# If your ES has security enabled, set these. Leave empty if not.
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=
ELASTICSEARCH_INDEX=rag_child_chunks

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=raw-documents
MINIO_SECURE=false

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── LLM — OpenRouter (default) ────────────────────────────────────────────────
# Get your key at: https://openrouter.ai
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free

# ── Embedding & Reranker ──────────────────────────────────────────────────────
# These are downloaded automatically from HuggingFace on first use (~1.3GB total)
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
RERANKER_MODEL=BAAI/bge-reranker-base

# ── Chunking Parameters ───────────────────────────────────────────────────────
CHILD_CHUNK_TARGET_TOKENS=400
CHILD_CHUNK_MAX_TOKENS=500
CHILD_CHUNK_OVERLAP_TOKENS=20
PARENT_CHUNK_TARGET_TOKENS=900

# ── Search Parameters ─────────────────────────────────────────────────────────
SEARCH_TOP_K_CHILDREN=20
RERANKER_TOP_N=5

# ── Cache ─────────────────────────────────────────────────────────────────────
CACHE_TTL_SECONDS=3600
